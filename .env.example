# ===========================================
# BizTrixVenture CRM - Environment Variables
# ===========================================
# PRODUCTION NOTES:
# - NODE_ENV should be 'production' at runtime (set in Coolify as "Runtime only")
# - Never commit actual keys to .env, use Coolify environment variables
# - Setting as "Runtime only" prevents exposure during Docker build

# ===== SECURITY & DEPLOYMENT =====
NODE_ENV=production
JWT_SECRET=your-32-character-random-secret-key-change-in-production
FRONTEND_URL=https://your-domain.com
API_PORT=4000

# ===== SUPABASE DATABASE =====
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service role key - NEVER expose to frontend
SUPABASE_ANON_KEY=eyJ...      # Anon key - used by frontend for auth only
SUPABASE_DB_PASSWORD=your-database-password

# ===== REDIS CACHE =====
# Local Docker: redis://redis:6379
# Managed (Upstash): rediss://default:[password]@[host]:[port]
REDIS_URL=redis://redis:6379
REDIS_CONNECT_TIMEOUT=5000
REDIS_DB=0

# ===== REDIS TTLs (in seconds) =====
NUMBER_SOLD_TTL=86400          # 24 hours
SESSION_TTL=28800              # 8 hours
NOTIFICATION_CACHE_TTL=300     # 5 minutes

# ===== REQUEST & API CONFIGURATION =====
REQUEST_TIMEOUT=30000          # 30 seconds
REQUEST_BODY_LIMIT=10mb        # Max request body size
ENABLE_COMPRESSION=true        # Enable gzip compression for responses

# ===== SOCKET.IO CONFIGURATION =====
SOCKET_PING_INTERVAL=30000     # 30 seconds
SOCKET_PING_TIMEOUT=60000      # 60 seconds
ENABLE_SOCKET_POLLING=true     # Fallback to polling if WebSocket fails

# ===== PAGINATION DEFAULTS =====
DEFAULT_PAGE_LIMIT=100
MAX_PAGE_LIMIT=500

# ===== RATE LIMITING =====
RATE_LIMIT_WINDOW_MS=900000    # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
SEARCH_RATE_LIMIT_MAX=30

# ===== 2FA CONFIGURATION =====
TOTP_ISSUER=BizTrixVenture

# ===== LOGGING =====
LOG_LEVEL=info                 # debug, info, warn, error (production: info)

# ===== OPTIONAL: IP GEOLOCATION (for audit logs) =====
# IP_API_KEY=your-ip-api-key
