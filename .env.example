# ===========================================
# BizTrixVenture CRM - Environment Variables
# ===========================================

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...   # Service role key - NEVER expose to frontend
SUPABASE_ANON_KEY=eyJ...      # Anon key - used by frontend for auth only

# API Configuration
JWT_SECRET=your-32-character-random-secret-key
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://your-domain.com

# Redis Configuration
REDIS_URL=redis://redis:6379  # or Upstash TLS URL for managed Redis

# 2FA Configuration
TOTP_ISSUER=BizTrixVenture

# Optional: IP Geolocation (for audit logs)
# IP_API_KEY=your-ip-api-key
